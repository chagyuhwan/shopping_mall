# 서버
PORT=3000
NODE_ENV=production

# 세션 (프로덕션에서 반드시 32자 이상 랜덤 문자열로 변경)
SESSION_SECRET=your-secret-key-here

# 관리자 (프로덕션: ADMIN_INITIAL_PASSWORD로 최초 비밀번호 설정)
ADMIN_EMAIL=admin
ADMIN_INITIAL_PASSWORD=

# HTTPS (프로덕션에서 리버스 프록시 뒤에 있을 때)
FORCE_HTTPS=true

# 이메일 (비밀번호 재설정용)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=KCSHOP <noreply@kcshop.com>

# 사이트 URL (이메일 링크용)
BASE_URL=https://your-domain.com

# 푸터 정보 (배포 시 실제 값으로 교체)
FOOTER_TEL=0000000
FOOTER_HOURS=평일 pm 13:00 - pm 19:00
FOOTER_ACCOUNT=국민 : 00000-00-00000
FOOTER_ADDRESS=서울시 강서구 마곡동
FOOTER_OWNER=차규환
FOOTER_OWNER_TEL=010-0000-0000
FOOTER_RETURN_ADDRESS=부산광역시 금정구 청량예진로 6 / 2층 KCSHOP
FOOTER_SNS=Instagram @kcshop

# 로깅
LOG_LEVEL=info
